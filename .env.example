# Vestigo environment configuration
# Copy this file to `.env` and adjust values for your environment.

# --- Application ---
VESTIGO_ENVIRONMENT=development
VESTIGO_LOG_LEVEL=INFO
VESTIGO_ALLOW_ONLINE=false

# --- PostgreSQL (metadata) ---
VESTIGO_POSTGRES_URL=postgresql+asyncpg://vestigo:vestigo@localhost:5432/vestigo

# --- ClickHouse (events) ---
VESTIGO_CLICKHOUSE_URL=http://localhost:8123
VESTIGO_CLICKHOUSE_DATABASE=vestigo
VESTIGO_CLICKHOUSE_USERNAME=default
VESTIGO_CLICKHOUSE_PASSWORD=

# --- Qdrant (vectors) ---
VESTIGO_QDRANT_URL=http://localhost:6333
# VESTIGO_QDRANT_API_KEY=
VESTIGO_QDRANT_COLLECTION_PREFIX=vestigo
# Set to a directory path to use Qdrant local mode instead of a server
# VESTIGO_QDRANT_PATH=

# --- Embeddings ---
VESTIGO_EMBEDDING_MODEL=all-MiniLM-L6-v2
VESTIGO_EMBEDDING_DEVICE=cpu
VESTIGO_EMBEDDING_BATCH_SIZE=64
# Set VESTIGO_EMBEDDING_API_BASE_URL to use a remote OpenAI-compatible embeddings
# endpoint instead of the local model. VESTIGO_EMBEDDING_MODEL is sent as the
# request's "model" field.
# VESTIGO_EMBEDDING_API_BASE_URL=https://api.openai.com/v1
# VESTIGO_EMBEDDING_API_KEY=

# --- Ingestion ---
# Events per ClickHouse insert during ingestion. One HTTP round-trip per
# batch, so larger batches amortize LAN latency (ClickHouse guidance:
# 10k-100k rows/insert). ~50-150 MB transient memory at the default.
# VESTIGO_INGEST_BATCH_SIZE=20000

# Events read per ClickHouse round-trip while an enrichment job scans a
# source. Enrichment is I/O-bound (every event scanned, not model-bound like
# embedding), so this pages large. On a 180M-event timeline: ~9k round-trips
# at 20000 vs ~180k at the old 1000-row floor. Kept separate from
# VESTIGO_EMBEDDING_BATCH_SIZE on purpose.
# VESTIGO_ENRICHMENT_BATCH_SIZE=20000

# --- Sigma rule runner ---
# Directory of Sigma YAML rules (offline file drop, e.g. a SigmaHQ clone) —
# re-read on every listing/run, no restart needed. Empty/unset disables the
# global set; analysts can still upload per-case rules through the UI.
# VESTIGO_SIGMA_RULES_PATH=/opt/sigma-rules
# Postgres rows per write batch while a Sigma run persists hits.
# VESTIGO_SIGMA_ANNOTATION_BATCH_SIZE=5000

# --- Uploads ---
# Maximum accepted source-upload size in bytes; 0 disables the limit.
# Default: 10 GiB. For very large files (tens of GiB+), prefer server-side
# 'vestigo ingest' over the HTTP upload — no size limit, no temp copy.
# VESTIGO_MAX_UPLOAD_BYTES=10737418240

# --- Frontend ---
# vestigo-web serves the prebuilt frontend/dist as-is and only builds it (npm
# install + build, requires network/node) when dist/ is missing. Set to 1 to
# force a rebuild after changing frontend sources.
# VESTIGO_FRONTEND_REBUILD=0

# --- Authentication: admin bootstrap ---
# On first startup, if no users exist yet, an administrator account is
# seeded with these credentials. The admin is forced to change the password
# on first login, which invalidates VESTIGO_ADMIN_PASSWORD immediately after —
# treat it as a one-time bootstrap secret, not a long-lived credential.
VESTIGO_ADMIN_USERNAME=admin
# VESTIGO_ADMIN_PASSWORD=

# --- Authentication: login backoff ---
# After this many consecutive failures per (username, client IP), logins are
# rejected with 429 for base*2^(n-threshold) seconds, capped at max.
# VESTIGO_LOGIN_BACKOFF_THRESHOLD=5
# VESTIGO_LOGIN_BACKOFF_BASE_SECONDS=2.0
# VESTIGO_LOGIN_BACKOFF_MAX_SECONDS=300.0

# --- Authentication: sessions ---
VESTIGO_SESSION_TTL_HOURS=168
VESTIGO_AUTH_COOKIE_NAME=tv_session
# Set to true when serving over HTTPS (required for the cookie to be sent).
VESTIGO_AUTH_COOKIE_SECURE=false
VESTIGO_AUTH_COOKIE_SAMESITE=lax

# --- Authentication: audit log ---
VESTIGO_AUDIT_ENABLED=true

# --- Authentication: optional OIDC (Authentik, Nextcloud, or any OIDC IdP) ---
# New OIDC logins are auto-provisioned into a team-less "default pool"
# (visible only to themselves) until an admin assigns them to a team.
VESTIGO_OIDC_ENABLED=false
# VESTIGO_OIDC_ISSUER=https://auth.example.org/application/o/vestigo/
# VESTIGO_OIDC_CLIENT_ID=
# VESTIGO_OIDC_CLIENT_SECRET=
# VESTIGO_OIDC_SCOPES=openid email profile
# VESTIGO_OIDC_REDIRECT_URL=http://localhost:8080/api/auth/oidc/callback

# --- Optional AI investigation agent (docs/AGENT.md) ---
# Off (and invisible in the UI) unless a model + endpoint are configured AND
# the endpoint answers a probe. Independent of VESTIGO_ALLOW_ONLINE — like
# OIDC and the embeddings endpoint, this is an operator-chosen endpoint.
#
# Local ollama example:
# VESTIGO_AGENT_MODEL=qwen3:32b
# VESTIGO_AGENT_PROVIDER=openai
# VESTIGO_AGENT_API_BASE_URL=http://localhost:11434/v1
#
# Kimi coding plan example (Anthropic-protocol endpoint; requires a coding-
# agent User-Agent or the endpoint returns 403). Model IDs: kimi-for-coding,
# k3, kimi-for-coding-highspeed (use the ID, not the version name):
# VESTIGO_AGENT_MODEL=kimi-for-coding
# VESTIGO_AGENT_PROVIDER=anthropic
# VESTIGO_AGENT_API_BASE_URL=https://api.kimi.com/coding
# VESTIGO_AGENT_API_KEY=sk-kimi-...
# VESTIGO_AGENT_USER_AGENT=claude-code/0.1.0
#
# VESTIGO_AGENT_EXTRA_HEADERS={"X-Example":"1"}
# VESTIGO_AGENT_MAX_TURNS=15
# Reasoning effort: off (default) | low | medium | high | max — translated per
# provider (docs/AGENT.md "Reasoning effort"). Env value pins the admin-UI field.
# VESTIGO_AGENT_REASONING_EFFORT=high
# Availability probe cache TTL in seconds (env-only, not admin-editable):
# VESTIGO_AGENT_PROBE_TTL_SECONDS=60
# Where the LLM API key may live: db (default; admins can store it in Postgres,
# plaintext at rest) or env-only (DB storage refused, any previously stored key
# ignored — VESTIGO_AGENT_API_KEY becomes the only source). Recommended for
# deployments where the Postgres host is less trusted than the app host:
# VESTIGO_AGENT_SECRET_MODE=env-only
#
# All VESTIGO_AGENT_* fields above (except the probe TTL) are also editable in
# the admin UI (Admin -> Agent); a set env var always wins over the DB value
# and shows as "pinned" there.

# --- External MCP endpoint (docs/AGENT.md) ---
# Serve the agent's tool set to external MCP clients over /mcp (streamable
# HTTP, per-timeline bearer tokens). Off by default; independent of the
# VESTIGO_AGENT_* settings above.
# VESTIGO_MCP_ENABLED=true

# --- Detector scan guardrails (heavy ClickHouse scans) ---
# Total memory budget shared by all concurrent heavy scans; each query gets
# budget / VESTIGO_STAT_SCAN_CONCURRENCY as its max_memory_usage. 0 = auto:
# VESTIGO_STAT_SCAN_MEMORY_RATIO of detected RAM (container cgroup limit when set,
# physical RAM otherwise). Pin a byte value when ClickHouse runs on a
# different host than the app — ~70% of *that* host's RAM, leaving headroom
# for the server's own caches/merges.
VESTIGO_STAT_SCAN_MAX_MEMORY_BYTES=0
VESTIGO_STAT_SCAN_MEMORY_RATIO=0.8
# Max detector scans running at once; surplus scans queue in the app.
VESTIGO_STAT_SCAN_CONCURRENCY=2
