# TraceSignal environment configuration
# Copy this file to `.env` and adjust values for your environment.

# --- Application ---
TS_ENVIRONMENT=development
TS_LOG_LEVEL=INFO
TS_ALLOW_ONLINE=false

# --- PostgreSQL (metadata) ---
TS_POSTGRES_URL=postgresql+asyncpg://tracesignal:tracesignal@localhost:5432/tracesignal

# --- ClickHouse (events) ---
TS_CLICKHOUSE_URL=http://localhost:8123
TS_CLICKHOUSE_DATABASE=tracesignal
TS_CLICKHOUSE_USERNAME=default
TS_CLICKHOUSE_PASSWORD=

# --- Qdrant (vectors) ---
TS_QDRANT_URL=http://localhost:6333
# TS_QDRANT_API_KEY=
TS_QDRANT_COLLECTION_PREFIX=tracesignal
# Set to a directory path to use Qdrant local mode instead of a server
# TS_QDRANT_PATH=

# --- Embeddings ---
TS_EMBEDDING_MODEL=all-MiniLM-L6-v2
TS_EMBEDDING_DEVICE=cpu
TS_EMBEDDING_BATCH_SIZE=64
# Set TS_EMBEDDING_API_BASE_URL to use a remote OpenAI-compatible embeddings
# endpoint instead of the local model. TS_EMBEDDING_MODEL is sent as the
# request's "model" field.
# TS_EMBEDDING_API_BASE_URL=https://api.openai.com/v1
# TS_EMBEDDING_API_KEY=

# --- Ingestion ---
# Events per ClickHouse insert during ingestion. One HTTP round-trip per
# batch, so larger batches amortize LAN latency (ClickHouse guidance:
# 10k-100k rows/insert). ~50-150 MB transient memory at the default.
# TS_INGEST_BATCH_SIZE=20000

# --- Uploads ---
# Maximum accepted source-upload size in bytes; 0 disables the limit.
# Default: 10 GiB. For very large files (tens of GiB+), prefer server-side
# 'tsig ingest' over the HTTP upload — no size limit, no temp copy.
# TS_MAX_UPLOAD_BYTES=10737418240

# --- Frontend ---
# tsig-web serves the prebuilt frontend/dist as-is and only builds it (npm
# install + build, requires network/node) when dist/ is missing. Set to 1 to
# force a rebuild after changing frontend sources.
# TS_FRONTEND_REBUILD=0

# --- Authentication: admin bootstrap ---
# On first startup, if no users exist yet, an administrator account is
# seeded with these credentials. The admin is forced to change the password
# on first login, which invalidates TS_ADMIN_PASSWORD immediately after —
# treat it as a one-time bootstrap secret, not a long-lived credential.
TS_ADMIN_USERNAME=admin
# TS_ADMIN_PASSWORD=

# --- Authentication: login backoff ---
# After this many consecutive failures per (username, client IP), logins are
# rejected with 429 for base*2^(n-threshold) seconds, capped at max.
# TS_LOGIN_BACKOFF_THRESHOLD=5
# TS_LOGIN_BACKOFF_BASE_SECONDS=2.0
# TS_LOGIN_BACKOFF_MAX_SECONDS=300.0

# --- Authentication: sessions ---
TS_SESSION_TTL_HOURS=168
TS_AUTH_COOKIE_NAME=tv_session
# Set to true when serving over HTTPS (required for the cookie to be sent).
TS_AUTH_COOKIE_SECURE=false
TS_AUTH_COOKIE_SAMESITE=lax

# --- Authentication: audit log ---
TS_AUDIT_ENABLED=true

# --- Authentication: optional OIDC (Authentik, Nextcloud, or any OIDC IdP) ---
# New OIDC logins are auto-provisioned into a team-less "default pool"
# (visible only to themselves) until an admin assigns them to a team.
TS_OIDC_ENABLED=false
# TS_OIDC_ISSUER=https://auth.example.org/application/o/tracesignal/
# TS_OIDC_CLIENT_ID=
# TS_OIDC_CLIENT_SECRET=
# TS_OIDC_SCOPES=openid email profile
# TS_OIDC_REDIRECT_URL=http://localhost:8080/api/auth/oidc/callback
